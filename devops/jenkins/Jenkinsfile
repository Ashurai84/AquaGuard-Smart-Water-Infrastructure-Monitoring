pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID = '123456789012'
        AWS_DEFAULT_REGION = 'us-east-1'
        IMAGE_REPO_BACKEND = 'aquaguard-backend'
        IMAGE_REPO_FRONTEND = 'aquaguard-frontend'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        EKS_CLUSTER_NAME = 'aquaguard-prod-eks'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm install --only=production'
                }
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('backend') {
                    echo "Executing backend unit testing..."
                    // sh 'npm test'
                }
            }
        }

        stage('Build Backend Image') {
            steps {
                script {
                    dockerBackend = docker.build("${IMAGE_REPO_BACKEND}:${IMAGE_TAG}", "-f backend/Dockerfile ./backend")
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                script {
                    dockerFrontend = docker.build("${IMAGE_REPO_FRONTEND}:${IMAGE_TAG}", "-f frontend/Dockerfile ./frontend")
                }
            }
        }

        stage('Push Images') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
                    
                    sh "docker tag ${IMAGE_REPO_BACKEND}:${IMAGE_TAG} ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_BACKEND}:${IMAGE_TAG}"
                    sh "docker tag ${IMAGE_REPO_FRONTEND}:${IMAGE_TAG} ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_FRONTEND}:${IMAGE_TAG}"
                    
                    sh "docker push ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_BACKEND}:${IMAGE_TAG}"
                    sh "docker push ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_FRONTEND}:${IMAGE_TAG}"
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    sh "aws eks update-kubeconfig --region ${AWS_DEFAULT_REGION} --name ${EKS_CLUSTER_NAME}"
                    sh "sed -i 's|IMAGE_PLACEHOLDER_BACKEND|${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_BACKEND}:${IMAGE_TAG}|g' devops/kubernetes/backend-deployment.yaml"
                    sh "sed -i 's|IMAGE_PLACEHOLDER_FRONTEND|${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${IMAGE_REPO_FRONTEND}:${IMAGE_TAG}|g' devops/kubernetes/frontend-deployment.yaml"
                    sh "kubectl apply -f devops/kubernetes/"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    // Poll service health status
                    echo "Checking API gateway ingress statuses..."
                    sh "curl -f http://aquaguard.internal/api/health || exit 1"
                }
            }
        }

        stage('Rollback') {
            when {
                expression { currentBuild.result == 'FAILURE' }
            }
            steps {
                script {
                    echo "Deployment failed. Rolling back changes..."
                    sh "kubectl rollout undo deployment/aquaguard-backend"
                    sh "kubectl rollout undo deployment/aquaguard-frontend"
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline finished with failure status. Rollback stage triggered."
        }
        success {
            echo "CI/CD execution completed successfully."
        }
    }
}
